{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/b/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/u/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/g/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/c/(.*)",
      "destination": "/404.html"
    }
  ]
}
